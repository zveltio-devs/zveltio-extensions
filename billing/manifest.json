{
  "name": "billing",
  "displayName": "Billing & Usage",
  "category": "billing",
  "description": "Usage metering and Stripe billing integration",
  "version": "1.0.0",
  "zveltioMinVersion": "1.0.0",
  "zveltioMaxVersion": "2.0.0",
  "package": "@zveltio/ext-billing",
  "permissions": [
    "database"
  ],
  "engine": {
    "entry": "engine/index.js",
    "format": "esm",
    "target": "bun",
    "bundled": true,
    "bundlePeers": false
  },
  "studio": {
    "pages": [
      {
        "path": "/admin/billing",
        "component": "./studio/src/pages/BillingPage.svelte",
        "label": "Billing",
        "icon": "credit-card"
      },
      {
        "path": "/admin/billing/usage",
        "component": "./studio/src/pages/UsagePage.svelte",
        "label": "Usage",
        "icon": "bar-chart"
      }
    ],
    "navGroup": "finance"
  },
  "contributes": {
    "engine": true,
    "studio": false,
    "fieldTypes": []
  },
  "integrity": {
    "engineSha256": "3a9233322806972a43dfeacbaea0ff379ba4a75b4d4e02e59638ee44a9176295"
  }
}
