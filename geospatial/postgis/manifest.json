{
  "name": "postgis",
  "package": "@zveltio/ext-postgis",
  "category": "geospatial",
  "displayName": "PostGIS",
  "description": "Geospatial queries — proximity search, bounding box, polygon containment",
  "version": "1.0.0",
  "zveltioMinVersion": "1.0.0",
  "zveltioMaxVersion": "2.0.0",
  "permissions": ["database"],
  "requires": {
    "postgres_extensions": ["postgis"]
  },
  "contributes": {
    "engine": true,
    "studio": true,
    "client": true,
    "clientComponents": ["MapPicker"],
    "studioComponents": ["MapPicker", "LocationField", "MapView"],
    "fieldTypes": ["location", "polygon", "linestring"]
  }
}
