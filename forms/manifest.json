{
  "name": "forms",
  "displayName": "Form Builder",
  "category": "forms",
  "description": "Drag-and-drop form builder with public submission endpoints",
  "version": "1.0.0",
  "zveltioMinVersion": "1.0.0",
  "zveltioMaxVersion": "2.0.0",
  "package": "@zveltio/ext-forms",
  "permissions": [
    "database"
  ],
  "engine": {
    "routes": "./engine/routes.ts",
    "mountPath": "/extensions/forms"
  },
  "studio": {
    "pages": [
      {
        "path": "/admin/forms",
        "component": "./studio/src/pages/FormsPage.svelte",
        "label": "Forms",
        "icon": "file-text"
      },
      {
        "path": "/admin/forms/:id",
        "component": "./studio/src/pages/FormBuilderPage.svelte",
        "label": "Form Builder",
        "icon": "edit"
      },
      {
        "path": "/admin/forms/:id/responses",
        "component": "./studio/src/pages/FormResponsesPage.svelte",
        "label": "Form Responses",
        "icon": "inbox"
      }
    ]
  },
  "contributes": {
    "engine": true,
    "studio": false,
    "fieldTypes": []
  }
}
