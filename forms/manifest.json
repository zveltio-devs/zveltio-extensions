{
  "name": "forms",
  "displayName": "Form Builder",
  "category": "forms",
  "description": "Drag-and-drop form builder with public submission endpoints",
  "version": "1.0.0",
  "zveltioMinVersion": "1.0.0",
  "zveltioMaxVersion": "4.0.0",
  "package": "@zveltio/ext-forms",
  "permissions": [
    "database"
  ],
  "engine": {
    "entry": "engine/index.js",
    "format": "esm",
    "target": "bun",
    "bundled": true,
    "bundlePeers": false
  },
  "studio": {
    "pages": [
      {
        "path": "/admin/forms",
        "component": "./studio/src/pages/FormsPage.svelte",
        "label": "Forms",
        "icon": "file-text"
      },
      {
        "path": "/admin/forms/:id",
        "component": "./studio/src/pages/FormBuilderPage.svelte",
        "label": "Form Builder",
        "icon": "edit"
      },
      {
        "path": "/admin/forms/:id/responses",
        "component": "./studio/src/pages/FormResponsesPage.svelte",
        "label": "Form Responses",
        "icon": "inbox"
      }
    ],
    "navGroup": "content"
  },
  "contributes": {
    "engine": true,
    "studio": false,
    "fieldTypes": []
  },
  "integrity": {
    "engineSha256": "92aa4679cf239b7529e1e9f89b494c0e2f3dd426ef5083ffac11207e2c2a1b41"
  }
}
