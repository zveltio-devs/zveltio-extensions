{
  "name": "zveltio-extensions",
  "version": "1.0.0",
  "private": true,
  "description": "Official Zveltio extensions — analytics, auth, automation, communications, compliance, content, CRM, data, developer tools, geospatial, i18n, multitenancy, operations, storage, workflow.",
