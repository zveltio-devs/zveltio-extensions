    "hono": "^4.4.0",
    "kysely": "^0.27.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "bun-types": "latest",
    "svelte": "^5.0.0",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0"
  }
}
