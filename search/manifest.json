{
  "name": "search",
  "displayName": "Search Adapter",
  "category": "search",
  "description": "Full-text search via MeiliSearch or Typesense with automatic record sync",
  "version": "1.0.0",
  "zveltioMinVersion": "1.0.0",
  "zveltioMaxVersion": "2.0.0",
  "package": "@zveltio/ext-search",
  "permissions": [
    "database"
  ],
  "engine": {
    "routes": "./engine/routes.ts",
    "mountPath": "/extensions/search"
  },
  "studio": {
    "pages": [
      {
        "path": "/admin/search",
        "component": "./studio/src/pages/SearchPage.svelte",
        "label": "Search",
        "icon": "search"
      }
    ],
    "navGroup": "developer"
  },
  "contributes": {
    "engine": true,
    "studio": false,
    "fieldTypes": []
  }
}
