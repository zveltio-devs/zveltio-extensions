{
  "name": "search",
  "displayName": "Search Adapter",
  "category": "search",
  "description": "Full-text search via MeiliSearch or Typesense with automatic record sync",
  "version": "1.0.0",
  "zveltioMinVersion": "1.0.0",
  "zveltioMaxVersion": "4.0.0",
  "package": "@zveltio/ext-search",
  "permissions": [
    "database"
  ],
  "engine": {
    "entry": "engine/index.js",
    "format": "esm",
    "target": "bun",
    "bundled": true,
    "bundlePeers": false
  },
  "studio": {
    "pages": [
      {
        "path": "/admin/search",
        "component": "./studio/src/pages/SearchPage.svelte",
        "label": "Search",
        "icon": "search"
      }
    ],
    "navGroup": "developer"
  },
  "contributes": {
    "engine": true,
    "studio": false,
    "fieldTypes": []
  },
  "integrity": {
    "engineSha256": "5bd109aa3402a2083d287e0e887fd3b410515a7bb5531539925aa2af0c668b21"
  }
}
