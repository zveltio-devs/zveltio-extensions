{
  "name": "communications/mail",
  "displayName": "Mail Client",
  "category": "communications",
  "description": "Full IMAP/SMTP email client with AI features, Sieve filtering, and contacts",
  "version": "1.0.0",
  "zveltioMinVersion": "1.0.0",
  "zveltioMaxVersion": "2.0.0",
  "package": "@zveltio/ext-mail",
  "permissions": [
    "database",
    "settings"
  ],
  "dependencies": [
    { "name": "ai", "minVersion": "1.0.0" }
  ],
  "peerDependencies": {
    "imapflow": "^1.0.0",
    "mailparser": "^3.6.0",
    "nodemailer": "^6.9.0"
  },
  "contributes": {
    "engine": true,
    "studio": true,
    "fieldTypes": [],
    "studioPages": [
      {
        "path": "mail",
        "component": "MailPage",
        "label": "Mail",
        "icon": "mail"
      },
      {
        "path": "mail/settings",
        "component": "MailSettingsPage",
        "label": "Mail Settings",
        "icon": "settings"
      }
    ]
  }
}
