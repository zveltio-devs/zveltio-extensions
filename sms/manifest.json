{
  "name": "sms",
  "displayName": "SMS / Push Notifications",
  "category": "sms",
  "description": "Send SMS via Twilio or Vonage with templates and delivery tracking",
  "version": "1.0.0",
  "zveltioMinVersion": "1.0.0",
  "zveltioMaxVersion": "2.0.0",
  "package": "@zveltio/ext-sms",
  "permissions": [
    "database"
  ],
  "engine": {
    "routes": "./engine/routes.ts",
    "mountPath": "/extensions/sms"
  },
  "studio": {
    "pages": [
      {
        "path": "/admin/sms",
        "component": "./studio/src/pages/SmsPage.svelte",
        "label": "SMS",
        "icon": "message-square"
      }
    ]
  },
  "contributes": {
    "engine": true,
    "studio": false,
    "fieldTypes": []
  }
}
