{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@zveltio/sdk": ["../zveltio/packages/sdk/src/index.ts"],
      "@zveltio/sdk/*": ["../zveltio/packages/sdk/src/*"],
      "svelte": ["../zveltio/packages/studio/node_modules/svelte"],
      "svelte/*": ["../zveltio/packages/studio/node_modules/svelte/*"],
      "@lucide/svelte": ["../zveltio/packages/studio/node_modules/@lucide/svelte"],
      "@lucide/svelte/*": ["../zveltio/packages/studio/node_modules/@lucide/svelte/*"],
      "hono": ["../zveltio/packages/engine/node_modules/hono/dist/types/index.d.ts"],
      "hono/*": ["../zveltio/packages/engine/node_modules/hono/dist/types/*"],
      "zod": ["../zveltio/packages/engine/node_modules/zod/index.d.ts"],
      "zod/*": ["../zveltio/packages/engine/node_modules/zod/*"],
      "@hono/zod-validator": ["../zveltio/packages/engine/node_modules/@hono/zod-validator/dist/index.d.ts"],
      "kysely": ["../zveltio/packages/engine/node_modules/kysely/dist/cjs/index.d.ts"],
      "kysely/*": ["../zveltio/packages/engine/node_modules/kysely/dist/cjs/*"],
      "better-auth": ["../zveltio/packages/engine/node_modules/better-auth/dist/index.d.ts"],
      "better-auth/*": ["../zveltio/packages/engine/node_modules/better-auth/dist/*"]
    },
    "typeRoots": [
      "../zveltio/packages/studio/node_modules/@types",
      "../zveltio/packages/engine/node_modules/@types"
    ]
  },
  "include": [
    "**/*.svelte",
    "**/*.ts"
  ],
  "exclude": [
    "**/node_modules",
    "**/dist"
  ]
}
